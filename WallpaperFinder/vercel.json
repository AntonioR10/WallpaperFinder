{
  "version": 2,
  "framework": "vite",
  "builds": [
    {
      "src": "api/index.go",
      "use": "@vercel/go"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "rewrites": [
    {
      "source": "/api/index",
      "destination": "/api/index.go"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1.go"
    }
  ]
}